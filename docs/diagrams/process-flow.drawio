<mxfile host="app.diagrams.net">
  <diagram name="Process Flow" id="process-flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1450" pageHeight="1400" math="0" shadow="0" background="#ffffff">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- White background container -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;" vertex="1" parent="1">
          <mxGeometry x="30" y="90" width="1390" height="1260" as="geometry" />
        </mxCell>

        <!-- Title -->
        <mxCell id="title" value="Prospect-Assist-AI — Lead Scoring Process Flow" style="text;html=1;fontSize=22;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Every box below is a real module in services/scoring-service; every gate is real logic in scoring_engine/tiering.py." style="text;html=1;fontSize=12;fontStyle=2;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="900" height="20" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="Customer transaction data&#10;(bank statement upload / synthetic)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="500" y="120" width="280" height="70" as="geometry" />
        </mxCell>

        <!-- Ingestion -->
        <mxCell id="ingest" value="Ingestion + Categorization&#10;(needs / obligations / discretionary / savings)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="500" y="230" width="280" height="60" as="geometry" />
        </mxCell>

        <!-- Income decision -->
        <mxCell id="empDecision" value="Employment type?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="540" y="330" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="salaried" value="Salaried:&#10;median + stability score" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="130" y="450" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gig" value="Gig / irregular:&#10;recency-weighted, volatility-discounted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="400" y="450" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="business" value="Business owner:&#10;turnover × industry margin band" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="700" y="450" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Capacity engine -->
        <mxCell id="capacity" value="Capacity Engine&#10;FOIR + affordability per loan product (Personal / Auto / Home / Mortgage)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="470" y="560" width="340" height="65" as="geometry" />
        </mxCell>

        <!-- Discipline engine -->
        <mxCell id="discipline" value="Discipline Engine&#10;day-1 spend velocity · bounced payments · balance check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="470" y="660" width="340" height="65" as="geometry" />
        </mxCell>

        <!-- Intent -->
        <mxCell id="intent" value="Intent Engine&#10;loan-application funnel depth (viewed offer → disbursed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="900" y="660" width="300" height="65" as="geometry" />
        </mxCell>

        <!-- Composite scoring -->
        <mxCell id="scoring" value="Composite Scoring Engine&#10;weighted: intent + capacity + discipline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="500" y="770" width="280" height="65" as="geometry" />
        </mxCell>

        <!-- Gate 1 -->
        <mxCell id="gate1" value="Never started&#10;an application?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="530" y="875" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="capped1" value="Capped: Interested / Not Qualified&#10;(intent gate) — regardless of finances" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="900" y="880" width="300" height="60" as="geometry" />
        </mxCell>

        <!-- Gate 2 -->
        <mxCell id="gate2" value="Discipline red flag?&#10;(bounced payment or high day-1 spend)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="510" y="1005" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="capped2" value="Capped: Quality / Interested&#10;(discipline gate) — regardless of income" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="900" y="1010" width="300" height="60" as="geometry" />
        </mxCell>

        <!-- Normal thresholds -->
        <mxCell id="normal" value="Composite-score thresholds&#10;(no gate triggered)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="500" y="1150" width="280" height="60" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="Tiered Lead:&#10;Serious / Quality / Interested / Not Qualified" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="470" y="1250" width="340" height="70" as="geometry" />
        </mxCell>

        <!-- Downstream -->
        <mxCell id="downstream" value="RM Dashboard · Lead Detail (“why this score”) · Underwriting Report Export" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1080" y="1250" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- Account Aggregator side-flow -->
        <mxCell id="aaHeader" value="Multi-account cross-check (RM-triggered, any time)" style="text;html=1;fontSize=13;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="1000" y="120" width="360" height="20" as="geometry" />
        </mxCell>
        <mxCell id="aa1" value="RM: Link another bank account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="150" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="aa2" value="Request consent&#10;(purpose, date range, expiry)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="215" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="aa3" value="Customer approves&#10;in their AA app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="285" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="aa4" value="Fetch FI data → merge&#10;into consolidated capacity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="355" width="260" height="55" as="geometry" />
        </mxCell>

        <!-- Edges: main pipeline -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="start" target="ingest"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="ingest" target="empDecision"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="salaried" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="empDecision" target="salaried"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="gig" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="empDecision" target="gig"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="business owner" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="empDecision" target="business"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="salaried" target="capacity"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="gig" target="capacity"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="business" target="capacity"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="capacity" target="discipline"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="discipline" target="scoring"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="intent" target="scoring"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="scoring" target="gate1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="gate1" target="capped1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="gate1" target="gate2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e15" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="gate2" target="capped2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e16" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="gate2" target="normal"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="normal" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="capped1" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="capped2" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="end" target="downstream"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Edges: AA side flow -->
        <mxCell id="ea1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#666666;" edge="1" parent="1" source="aa1" target="aa2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#666666;" edge="1" parent="1" source="aa2" target="aa3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#666666;" edge="1" parent="1" source="aa3" target="aa4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea4" value="adds a second account" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#666666;" edge="1" parent="1" source="aa4" target="capacity"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
