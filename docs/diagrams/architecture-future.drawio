        </mxCell>

        <!-- Migration sequence note -->
        <mxCell id="sequence" value="Suggested sequencing:&#10;1. RDS + apply existing migrations as-is (plain Postgres)&#10;2. S3 for storage; ingestion adapter swap only&#10;3. Cognito + verify RLS policies against real JWT claims&#10;4. Swap MockAAClient / MockCoreBankingClient one at a time&#10;5. SageMaker only after real labeled outcomes exist" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="420" y="800" width="380" height="150" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Pink/red = security &amp; management · Blue = database · Green = storage/compute · Purple = ML &amp; networking · Grey dashed = external/not-yet-wired · Red box = third-party (non-AWS)" style="text;html=1;fontSize=11;fontStyle=2;align=left;fontColor=#666666;" vertex="1" parent="1">
