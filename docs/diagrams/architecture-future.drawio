<mxfile host="app.diagrams.net">
  <diagram name="Future Architecture (AWS)" id="future-arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- White background container -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="90" width="1840" height="900" as="geometry" />
        </mxCell>

        <!-- Title -->
        <mxCell id="title" value="Prospect-Assist-AI — Stage 2 (AWS) Target Architecture" style="text;html=1;fontSize=22;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Nothing below is provisioned yet — same interfaces (IngestionSource / AAClient / CoreBankingClient) as the MVP, only the concrete implementation swaps. AWS icons are the standard draw.io AWS4 shape library. See docs/aws-migration-map.md." style="text;html=1;fontSize=12;fontStyle=2;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1300" height="20" as="geometry" />
        </mxCell>

